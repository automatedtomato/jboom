{
	"name": "jboom",
	"image": "oven/bun:latest",
	"workspaceFolder": "/home/bun/app",
	"mounts": ["source=${localWorkspaceFolder},target=/home/bun/app,type=bind"],
	"initializeCommand": "chmod -R a+rw ${localWorkspaceFolder}",
	"remoteUser": "bun",
	"postCreateCommand": "bun add -D -E @biomejs/biome"
}
